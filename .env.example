# =========================
# Core
# Explica el contexto de ejecución, la URL pública y el modo de interfaz del servicio.

AGORA_DEPLOY_TARGET=local # local | vps
AGORA_PUBLIC_URL=https://tu-dominio.com # URL pública completa; solo se usa cuando AGORA_DEPLOY_TARGET=vps
INTERFACE_MODE=api # terminal | api
UI_TEST=true # true | false
AGORA_API_HOST=0.0.0.0 # host/IP de bind de la API
AGORA_API_PORT=8000 # puerto entero de la API
AGORA_LOG_LEVEL=WARNING # DEBUG | INFO | WARNING | ERROR | CRITICAL
AGORA_POSTGRES_HOST=localhost # host de Postgres fuera de Docker; en Docker no hace falta tocarlo

# =========================
# Database
# Configura la base de datos principal de Agora; DATABASE_URL solo se usa como override avanzado.

POSTGRES_DB=agora # nombre de base de datos
POSTGRES_USER=agora_user # usuario de Postgres
POSTGRES_PASSWORD=change_me_strong_password # contraseña fuerte de Postgres
# DATABASE_URL=postgresql://agora_user:change_me_strong_password@localhost:5432/agora # DSN PostgreSQL completo; opcional si quieres override
# DATABASE_URL_TEST=postgresql://agora_user:change_me_strong_password@localhost:5432/agora_test # DSN opcional para tests

# =========================
# Game
# Ajusta parámetros funcionales del motor narrativo y del flujo entre agentes.

# GAME_THEME=intriga politica en madrid # tema semilla opcional por defecto
MAX_TURNS=20 # entero >= 1
NUM_ACTORS=3 # entero, habitualmente 1..5
CHAR_CONTEXT_MESSAGES=12 # entero >= 1
OBSERVER_CONTEXT_MESSAGES=10 # entero >= 1
OBSERVER_PARALLEL_EVAL=true # true | false
OBSERVER_ENABLE_NON_USER_CONTINUATION=false # true | false
AGORA_STREAM_CHARACTER=yes # 1 | true | yes | on | 0 | false | no | off
AGORA_STREAM_GUIONISTA=no # 1 | true | yes | on | 0 | false | no | off

# =========================
# LLM
# Define el proveedor/modelos del LLM y las tarifas usadas para calcular coste.

DEEPSEEK_API_KEY=change_me # API key válida del proveedor configurado
# DEEPSEEK_MODEL_CHARACTER=deepseek-chat # modelo opcional para personajes
# DEEPSEEK_TEMP_CHARACTER=2.0 # temperatura decimal opcional
DEEPSEEK_INPUT_COST_PER_1M_TOKENS=0.28 # coste input por 1M tokens
DEEPSEEK_OUTPUT_COST_PER_1M_TOKENS=1.10 # coste output por 1M tokens

# =========================
# Auth
# Controla autenticación, cookies, JWT y el usuario admin bootstrap.

AUTH_REQUIRED=true # true | false
# AUTH_SECRET_KEY=change_me_super_secret # secreto JWT fuerte; recomendado en producción
AUTH_ALGORITHM=HS256 # algoritmo JWT, ej. HS256
AUTH_COOKIE_NAME=agora_auth_token # nombre de la cookie HTTP
AUTH_TOKEN_EXPIRE_MINUTES=480 # minutos enteros >= 5
AUTH_SEED_USERNAME=admin # username del usuario bootstrap
AUTH_SEED_PASSWORD=4dmin # contraseña del usuario bootstrap
AUTH_SEED_ROLE=admin # admin | user

# =========================
# Observability
# Configura la emisión asíncrona de métricas del engine y el servicio de telemetría agregado.

TELEMETRY_ENABLED=true # true | false
# TELEMETRY_ENDPOINT=http://localhost:8081/v1/events # endpoint de ingesta opcional; si no, se calcula según contexto
TELEMETRY_INGEST_KEY=change_me_ingest_key # clave compartida fuerte entre engine y telemetry service
TELEMETRY_BATCH_SIZE=32 # entero >= 1
TELEMETRY_QUEUE_MAX=4096 # entero >= 1; tamaño máximo de cola en memoria
TELEMETRY_FLUSH_INTERVAL_SECONDS=1.5 # segundos decimales > 0
TELEMETRY_TIMEOUT_SECONDS=1.0 # segundos decimales > 0
# TELEMETRY_DB_PATH=/data/telemetry.db # path opcional del sqlite del servicio de telemetría
# TELEMETRY_MAX_BATCH=256 # entero >= 1; máximo de eventos aceptados por batch

# =========================
# Infisical
# Permite cargar secrets externos en runtime y en deploy; útil para un setup más production-style.

INFISICAL_ENABLED=false # true | false
INFISICAL_HOST=https://eu.infisical.com # URL base de tu región de Infisical
INFISICAL_CLIENT_ID= # Client ID de Universal Auth
INFISICAL_CLIENT_SECRET= # Client Secret de Universal Auth
INFISICAL_PROJECT_ID= # Project ID de Infisical
INFISICAL_ENV=prod # nombre del environment: prod | dev | staging | etc.
INFISICAL_SECRET_PATH=/ # carpeta/ruta de secrets
INFISICAL_INCLUDE_IMPORTS=true # true | false
INFISICAL_OVERRIDE_EXISTING=false # true | false
INFISICAL_TIMEOUT_SECONDS=5 # segundos decimales > 0

# =========================
# Legacy Compatibility
# Overrides heredados que siguen siendo compatibles, pero ya no son necesarios en la configuración nueva.

# AGORA_BASE_URL_LOCAL=http://localhost # URL local heredada; opcional
# AGORA_BASE_URL_VPS=http://85.17.246.141 # URL VPS heredada; opcional
